{"_id":"AfodViceFe000001","name":"Fe","type":"vice","img":"icons/magic/holy/angel-winged-humanoid-blue.webp","system":{"description":"<p>Estás dedicado a un poder invisible, ser espiritual, dios, ancestro, etc.</p><p>Detalla tu fe específica e indica el nombre y ubicación de tu proveedor de vicio (predicador, chamán, altar secreto, etc.).</p>"},"effects":[],"folder":null,"sort":100000,"ownership":{"default":0},"flags":{}}
